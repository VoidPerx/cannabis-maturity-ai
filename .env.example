# === Roboflow ===
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_WORKSPACE=your_workspace_slug
ROBOFLOW_TRICHOME_PROJECT=cannabis-trichomes
ROBOFLOW_STIGMA_PROJECT=cannabis-stigmas

# === App ===
APP_NAME=Cannabis Maturity AI
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# === Database ===
DATABASE_URL=sqlite:///./data/cannabis_maturity.db

# === Storage ===
UPLOAD_DIR=./data/raw
PROCESSED_DIR=./data/processed
MODELS_DIR=./data/models
EXPORTS_DIR=./data/exports

# === MLflow ===
MLFLOW_TRACKING_URI=./data/mlruns
MLFLOW_EXPERIMENT_NAME=cannabis-maturity-detection

# === Model ===
TRICHOME_MODEL_PATH=./data/models/trichome_detect.pt
STIGMA_MODEL_PATH=./data/models/stigma_seg.pt
CONFIDENCE_THRESHOLD=0.45
IOU_THRESHOLD=0.45
